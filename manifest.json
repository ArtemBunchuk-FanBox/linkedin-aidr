{
  "manifest_version": 3,
  "name": "LinkedIn AI:DR",
  "version": "0.1.0",
  "description": "AI; Didn't Read — filter AI-themed and AI-written posts from your LinkedIn feed.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://api.gptzero.me/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn AI:DR"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["detector.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
